static func groups() -> Array:
	return GROUPS.duplicate(true)


static func terms() -> Array:
	var result := []
	for group: Dictionary in GROUPS:
		for source_term: Dictionary in group.get("terms", []):
			var term := source_term.duplicate(true)
			term["category"] = str(group.get("name", "词条"))
			result.append(term)
	return result
